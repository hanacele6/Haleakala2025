# ----------------------------------------------------------------
# .py ファイルのみを追跡し、他はすべて無視するための .gitignore
# ----------------------------------------------------------------

# 1. すべてのファイルとディレクトリを無視
*

# 2. 追跡したいファイル拡張子を「例外」として許可
# これにより、`.py` ファイルだけは無視されなくなる
!*.py

# 3. ディレクトリの中身をチェックできるように、ディレクトリ自体は無視対象から外す
# これがないと、サブディレクトリ内の .py ファイルを見つけてくれない
!*/

# ----------------------------------------------------------------
# Pythonプロジェクトで一般的に無視されるもの 
# ----------------------------------------------------------------

# コンパイルされたPythonファイル
__pycache__/
*.py[cod]

# 仮想環境のディレクトリ (例: venv, .venv, env)
# 自分の環境に合わせて名前を変更・追加してください
/venv/
/.venv/
/env/

# IDEやエディタの設定ファイル (例: VSCode, PyCharm)
.vscode/
.idea/

# ----------------------------------------------------------------
# 追加で無視するもの
# ----------------------------------------------------------------
OLDver/
psg/
PIC/
kernels/
